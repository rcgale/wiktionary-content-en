==[[Ojibwe]]==
===Preverb===
ziigwan= (''consonant root'')<br>
ziigwani- (''lexical'')

#[[spring]], [[springtime]]

===Derived terms===
'''ziigwan='''
#'''ziigwan''' (''intransitive verb, inanimate subject'')
#:it is [[spring]], it is [[springtime]]
#'''[[ziigwanishi]]''' (''intransitive verb, animate subject'')
#:spend [[spring]] somewhere else
#'''[[ziigwanong]]''' (''particle'')
#:last [[spring]]
#'''[[awas-ziigwanong]]''' (''particle'')
#:[[spring]] before last
#'''[[ziigwanindaagwad]]''' (''intransitive verb, inanimate subject'')
#:it is considered to be [[spring]]

'''ziigwani-'''
#'''[[Ziigwani-gakaabikaang]]''' (''place'')
#:Seguin Falls, Ontario

===Transformations===
*ziigwan= (''unaffected'')
*zaagwan= (''initial change'')
*zaaziigwan= (''reduplication'')
*zayaaziigwan= (''initial change reduplication'')

