==Norwegian==

===Adverb===
'''av'''

#[[off#Adjective|off]]; not operating
#: ''å sla av'' -- ''to turn off''
#[[from]]
#: ''fra barn av'' = ''from childhood''
#[[of]]
#: ''bli av med'' = ''get rid of''
#[[now]]
#: ''[[av og til]]'' = ''[[now and then]]''

===Preposition===
'''av'''

#[[from]]
#:''I got it from…'' = ''Jeg fikk den av…''
#[[by]]; ''in construction of the passive tense''
#:''The house was painted by him'' = ''Huset ble malt av ham''
#[[of]]
#:''It is made of wood'' = ''Det er laget av tre''
#:''En av dem'' = ''One of them''
#[[for]]
#:''Av mange grunder'' = ''For many reasons''
#[[in]], [[out of]]
#:''En av hundre'' = ''One in a hundred''
#:''Av fortvilelse'' = ''Out of desperation''
#[[from]]
#:''Å komme av hesten'' = ''To come off the horse''
#[[on]]
#:''Avhenging av'' = ''Dependend on''

